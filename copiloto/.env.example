# Copia este archivo a .env y rellena los valores.

# Token del bot de Telegram (créalo hablando con @BotFather en Telegram)
TELEGRAM_BOT_TOKEN=

# chat_id del contacto de emergencia por defecto
# (para obtenerlo: escribe a tu bot y abre
#  https://api.telegram.org/bot<TOKEN>/getUpdates )
DEFAULT_CHAT_ID=
# --- Opcionales (tienen valores por defecto en config.py) ---
MODEL_NAME=chbh7051/driver-drowsiness-detection
LEVEL1_SECS=1.5
LEVEL2_SECS=4.0
INFER_EVERY=3
CAMERA_INDEX=0

# --- Incidencias por foto (QR + VLM) ---
# Postgres para almacenar anomalías. Si lo dejas vacío, se usa SQLite local.
# Con docker-compose: postgresql://copiloto:copiloto@localhost:5432/copiloto
DATABASE_URL=
# Modelo zero-shot para clasificar la anomalía
INCIDENT_MODEL=openai/clip-vit-base-patch32
# Confianza mínima para reportar automáticamente (si no, va a revisión humana)
INCIDENT_CONF_THRESHOLD=0.45
# URL pública para el QR (si usas un túnel ngrok). Vacío = autodetecta IP LAN.
PUBLIC_URL=
